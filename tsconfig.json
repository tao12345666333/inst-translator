{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["chrome"],
    "allowJs": false,
    "isolatedModules": true
  },
  "include": ["src/**/*", "manifest.json", "vite.config.ts"]
}
